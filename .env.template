# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# LLM Configuration
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_STREAMING=true

# Security
API_SECRET_KEY=generate_a_secure_random_key_here
ALLOWED_TARGETS=scanme.nmap.org,testphp.vulnweb.com
REQUIRE_TARGET_APPROVAL=true

# Paths
DATA_DIR=./data
LOGS_DIR=./logs
SESSIONS_DIR=./data/sessions
FINDINGS_DIR=./data/findings
REPORTS_DIR=./data/reports

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
MAX_CONCURRENT_SCANS=3
RATE_LIMIT_PER_MINUTE=30

# Tool Timeouts (seconds)
NMAP_TIMEOUT=300
NIKTO_TIMEOUT=600
SQLMAP_TIMEOUT=900
GOBUSTER_TIMEOUT=300
METASPLOIT_TIMEOUT=1800
