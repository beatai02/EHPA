# ============================================================================
# EHPA - Ethical Hacking Personal Assistant
# Environment Configuration Template
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:    cp .env.example .env
# 2. Fill in your actual values (especially API keys)
# 3. Never commit .env to version control (it's in .gitignore)
#
# ============================================================================

# ============================================================================
# REQUIRED: Anthropic Claude API
# ============================================================================
# Get your API key from: https://console.anthropic.com/settings/keys
# This is REQUIRED for LLM-powered decision making, chatbot, and analysis
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_ACTUAL_KEY

# ============================================================================
# REQUIRED: Hexstrike MCP Server (for 150+ security tools)
# ============================================================================
# Hexstrike MCP provides unified access to all security tools
# Get API key from: https://hexstrike.io/mcp
# Or run your own Hexstrike MCP server locally
HEXSTRIKE_MCP_URL=http://localhost:8888
HEXSTRIKE_API_KEY=your-hexstrike-api-key-here

# Set to 'true' if using Hexstrike, 'false' to use direct tool execution
HEXSTRIKE_ENABLED=true

# ============================================================================
# API Server Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change_this_to_a_secure_random_key_DO_NOT_USE_DEFAULT

# ============================================================================
# LLM Configuration
# ============================================================================
# Model to use (claude-sonnet-4-5-20250929 is recommended)
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_STREAMING=true

# ============================================================================
# Security & Authorization
# ============================================================================
# Comma-separated list of allowed targets for testing
# ONLY add targets you have permission to test!
ALLOWED_TARGETS=scanme.nmap.org,testphp.vulnweb.com

# Require explicit authorization for all targets
REQUIRE_TARGET_APPROVAL=true

# Require manual approval for exploitation and post-exploitation phases
REQUIRE_EXPLOITATION_APPROVAL=true
REQUIRE_POST_EXPLOITATION_APPROVAL=true

# ============================================================================
# File Paths
# ============================================================================
DATA_DIR=./data
LOGS_DIR=./logs
SESSIONS_DIR=./data/sessions
FINDINGS_DIR=./data/findings
REPORTS_DIR=./data/reports
CHAT_HISTORY_DIR=./data/chat_history

# ============================================================================
# Logging
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Options: text, json
LOG_FORMAT=text

# Enable verbose logging for debugging
VERBOSE_LOGGING=false

# ============================================================================
# Rate Limiting & Performance
# ============================================================================
# Maximum number of concurrent penetration test sessions
MAX_CONCURRENT_SCANS=3

# LLM API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# Maximum workflow iterations (safety limit to prevent infinite loops)
MAX_WORKFLOW_ITERATIONS=50

# ============================================================================
# Tool Timeouts (seconds)
# ============================================================================
# Default timeouts for various security tools
NMAP_TIMEOUT=300
NIKTO_TIMEOUT=600
SQLMAP_TIMEOUT=900
GOBUSTER_TIMEOUT=300
METASPLOIT_TIMEOUT=1800
NUCLEI_TIMEOUT=900
WPSCAN_TIMEOUT=600
AMASS_TIMEOUT=1800

# ============================================================================
# OSINT Configuration
# ============================================================================
# Enable automatic OSINT feed aggregation
OSINT_ENABLED=true

# How often to fetch security news (seconds, 3600 = 1 hour)
OSINT_FETCH_INTERVAL=3600

# ============================================================================
# Chatbot Configuration
# ============================================================================
# Enable chatbot interface
CHATBOT_ENABLED=true

# Maximum number of conversation messages to keep in memory
CHATBOT_MAX_CONTEXT_MESSAGES=20

# ============================================================================
# Optional: Additional API Keys
# ============================================================================
# Shodan API key for OSINT (optional but recommended)
# Get from: https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal API key (optional)
VIRUSTOTAL_API_KEY=

# SecurityTrails API key (optional)
SECURITYTRAILS_API_KEY=

# WPScan API token for WordPress vulnerability data (optional)
WPSCAN_API_TOKEN=

# ============================================================================
# Database Configuration (Optional - for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost/ehpa
# DATABASE_POOL_SIZE=10

# ============================================================================
# Email Notifications (Optional - for future use)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=admin@example.com

# ============================================================================
# Advanced Configuration
# ============================================================================
# Enable debug mode (WARNING: exposes sensitive information)
DEBUG_MODE=false

# Enable API documentation endpoints
ENABLE_API_DOCS=true

# Enable CORS for all origins (set to false in production)
CORS_ALLOW_ALL=true

# Specific CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://dashboard.example.com

# ============================================================================
# Kali Linux Tool Paths (auto-detected if on standard Kali installation)
# ============================================================================
# Only set these if tools are in non-standard locations
# NMAP_PATH=/usr/bin/nmap
# NIKTO_PATH=/usr/bin/nikto
# SQLMAP_PATH=/usr/bin/sqlmap
# GOBUSTER_PATH=/usr/bin/gobuster
# METASPLOIT_PATH=/usr/bin/msfconsole
# NUCLEI_PATH=/usr/bin/nuclei

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
#
# SECURITY REMINDERS:
# - Never commit .env to version control
# - Keep API keys secret and rotate them regularly
# - Use strong, unique secret keys
# - Only test targets you have authorization to test
# - Review logs for suspicious activity
#
# For more information, see: README.md and ARCHITECTURE.md
# ============================================================================
